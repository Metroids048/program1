# LLM keys — server-side only. No VITE_ prefix, so they are never inlined into
# the browser bundle. Default order: OpenRouter free pool -> GitHub Models ->
# DeepSeek -> local fallback.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_POOL=openrouter/free
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL_POOL=openai/gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional streaming ASR. When these are absent, the app falls back to Web
# Speech where available, then text input.
ASR_PROVIDER=xfyun
XFYUN_RTASR_APP_ID=
XFYUN_RTASR_API_KEY=
XFYUN_RTASR_ENDPOINT=wss://rtasr.xfyun.cn/v1/ws

# Optional local backend settings.
HOST=127.0.0.1
PORT=
SERVER_PORT=8787
AI_JOB_DB_PATH=.data/ai-job-platform.sqlite
APP_BASE_URL=http://127.0.0.1:5173
APP_CORS_ORIGIN=http://127.0.0.1:5173
JWT_SECRET=
SUPPORT_EMAIL=

# Local mail outbox (default mode for development and test)
MAIL_OUTBOX_PATH=.data/mail-outbox.json
MAIL_OUTBOX_LOG_PATH=.data/mail-outbox.log

# Optional search provider. Supported: tavily, bing, serpapi.
SEARCH_PROVIDER=
SEARCH_API_KEY=
