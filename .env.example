# DeepSeek API key — server-side only.
# Used by the lightweight proxy in vite.config.ts; NOT exposed to the browser bundle
# (no VITE_ prefix => never inlined into client code).
# Get one at https://platform.deepseek.com/ , then copy this file to .env.local and fill it in.
DEEPSEEK_API_KEY=

# Optional local backend settings.
HOST=127.0.0.1
PORT=
SERVER_PORT=8787
AI_JOB_DB_PATH=.data/ai-job-platform.sqlite
APP_BASE_URL=http://127.0.0.1:5173
APP_CORS_ORIGIN=http://127.0.0.1:5173
JWT_SECRET=
SUPPORT_EMAIL=

# Local mail outbox (default mode for development and test)
MAIL_OUTBOX_PATH=.data/mail-outbox.json
MAIL_OUTBOX_LOG_PATH=.data/mail-outbox.log

# Optional search provider. Supported: tavily, bing, serpapi.
SEARCH_PROVIDER=
SEARCH_API_KEY=
