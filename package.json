{
  "name": "campus-interview-ai-workbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "setup": "node scripts/doctor.mjs",
    "start": "node scripts/start-dev.mjs",
    "start:experience": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-experience.ps1",
    "dev": "node node_modules/vite/bin/vite.js --host 127.0.0.1 --configLoader runner",
    "server": "node node_modules/tsx/dist/cli.mjs server/index.ts",
    "dev:full": "tsx server/index.ts",
    "build": "node node_modules/typescript/bin/tsc -b && node node_modules/vite/bin/vite.js build --configLoader runner",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "typecheck:server": "node node_modules/typescript/bin/tsc -p tsconfig.server.json --noEmit",
    "test": "node node_modules/vitest/vitest.mjs run --configLoader runner",
    "test:full-flow": "node node_modules/tsx/dist/cli.mjs scripts/full-flow-retest.ts",
    "test:first-user": "node node_modules/tsx/dist/cli.mjs scripts/first-time-user-flow.ts",
    "test:ai-success-smoke": "node node_modules/tsx/dist/cli.mjs scripts/ai-success-smoke.ts",
    "test:browser-flow": "node node_modules/tsx/dist/cli.mjs scripts/external-browser-user-flow.ts",
    "test:browser-flow:headed": "node node_modules/tsx/dist/cli.mjs scripts/external-browser-user-flow.ts --headed",
    "test:server": "node node_modules/vitest/vitest.mjs run server/index.test.ts --configLoader runner",
    "test:app": "node node_modules/vitest/vitest.mjs run src/App.test.tsx src/components/positions.test.tsx src/components/questions.test.tsx src/components/records.test.tsx src/components/resume.test.tsx --configLoader runner",
    "test:acceptance": "npm run test:app && npm run test:server && npm run test:full-flow && npm run test:ai-success-smoke",
    "verify": "npm run lint && npm run typecheck:server && npm run test && npm run build",
    "verify:acceptance": "npm run verify && npm run test:acceptance",
    "sync:github": "node scripts/sync-to-github.mjs"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@vitejs/plugin-react": "^5.1.1",
    "better-sqlite3": "^12.10.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.16"
  }
}
